# 아보하 백엔드 환경변수 템플릿.
# 로컬에선 이 파일을 `.env` 로 복사한 뒤 값을 채워 사용.
# `.env` 는 gitignore 됨 (루트 .gitignore 참조).

NODE_ENV=development

# --- Kakao Developers (developers.kakao.com) ---
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# --- DB / Queue (로컬: docker-compose 기본값) ---
DATABASE_URL=postgres://avoha:avoha_dev@localhost:5432/avoha
REDIS_URL=redis://localhost:6379

# --- Auth / 세션 ---
# 세션 쿠키 암호화 키 (32바이트 hex). 생성: openssl rand -hex 32
SESSION_SECRET=

# --- 프론트엔드 (OAuth 콜백 redirect 대상) ---
FRONTEND_URL=http://localhost:5173

# --- Kakao 채널 / 상담톡 (BE-4 이후) ---
# KAKAO_CHANNEL_ID=
# KAKAO_BIZ_CHANNEL_UUID=

# --- 내부 서비스 URL ---
# REMBG_URL=http://localhost:8000

# --- 운영 알림 ---
# DISCORD_OPS_WEBHOOK=
